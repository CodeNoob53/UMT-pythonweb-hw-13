                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 OK with a valid reset_token', function () { pm.expect([200, 400]).to.include(pm.response.code); });",
                  "if (pm.response.code === 200) { pm.collectionVariables.set('password', pm.collectionVariables.get('new_password')); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/reset-password/confirm",
            "description": "Requires reset_token copied from the reset email. On success, password variable is updated to new_password.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{reset_token}}\",\n  \"new_password\": \"{{new_password}}\"\n}",
              "options": {
