        {
          "name": "Create upcoming birthday contact",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const birthdayDate = new Date();",
                  "birthdayDate.setDate(birthdayDate.getDate() + 3);",
                  "const month = String(birthdayDate.getMonth() + 1).padStart(2, '0');",
                  "const day = String(birthdayDate.getDate()).padStart(2, '0');",
                  "const year = 1970 + Math.floor(Math.random() * 40);",
                  "const suffix = `${Date.now()}${Math.floor(Math.random() * 1000)}`;",
                  "const contact = {",
                  "  first_name: 'Birthday',",
                  "  last_name: `Check${suffix}`,",
                  "  email: `birthday.check.${suffix}@example.com`,",
                  "  phone: `+380${Math.floor(100000000 + Math.random() * 900000000)}`,",
                  "  birthday: `${year}-${month}-${day}`,",
                  "  notes: 'Should appear in upcoming birthdays'",
                  "};",
                  "",
                  "pm.request.body.update(JSON.stringify(contact, null, 2));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 Created', function () {",
