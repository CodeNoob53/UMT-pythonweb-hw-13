              "raw": "{\n  \"first_name\": \"Generated\",\n  \"last_name\": \"Contact\",\n  \"email\": \"generated.contact@example.com\",\n  \"phone\": \"+380501112233\",\n  \"birthday\": \"1990-01-01\",\n  \"notes\": \"This body is replaced by the pre-request script\"\n}"
            },
