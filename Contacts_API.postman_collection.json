            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/reset-password/request",
            "description": "Always returns 200. Copy the reset token from the email link into reset_token before running Confirm password reset.",
