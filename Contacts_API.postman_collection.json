    {
      "name": "Auth",
      "item": [
        {
          "name": "Register user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "  const body = JSON.parse(pm.request.body.raw);",
                  "  pm.collectionVariables.set('username', body.username);",
                  "  pm.collectionVariables.set('email', body.email);",
                  "  pm.collectionVariables.set('password', body.password);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"your_username\",\n  \"email\": \"your_real_email@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{base_url}}/api/auth/register",
            "description": "Set username, email, and password collection variables before sending. Login will return 401 until email is confirmed."
          },
          "response": []
        },
        {
          "name": "Confirm email by token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('verify_token');",
                  "if (!token) {",
                  "  console.warn('verify_token is empty. Skipping email confirmation. Paste the token from email or confirm the user in the database before Login.');",
                  "  pm.execution.skipRequest();",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/auth/confirmed_email/{{verify_token}}",
            "description": "Paste the token from the verification email into the verify_token collection variable before sending."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', data.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                }
              ]
            },
            "url": "{{base_url}}/api/auth/login",
            "description": "Uses OAuth2PasswordRequestForm, so the body must be x-www-form-urlencoded. If this returns 401 after registration, confirm the user's email first."
          },
          "response": []
        }
      ]
    },
